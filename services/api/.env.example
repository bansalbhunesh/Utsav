# Backend (Go API) environment variables
# Copy to services/api/.env for local development.

# ---------- Required ----------
HTTP_PORT=8080
DATABASE_URL=postgres://utsav:utsav@127.0.0.1:5432/utsav?sslmode=disable
MIGRATIONS_PATH=../../db/migrations
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
CORS_ORIGIN=http://localhost:3000
RUN_MIGRATIONS=true
ENV=development

# ---------- OTP / Auth ----------
# Development fallback OTP. MUST be blank in production.
DEV_OTP_CODE=123456
OTP_MAX_ATTEMPTS=5

# OTP provider config (MSG91 recommended for India)
OTP_PROVIDER=msg91
OTP_API_KEY=
OTP_API_SECRET=
OTP_SENDER_ID=

# ---------- Storage ----------
OBJECT_STORE_PUBLIC_BASE_URL=http://127.0.0.1:9000/utsav
OBJECT_STORE_BUCKET=utsav
OBJECT_STORE_REGION=auto

# ---------- Payments ----------
RAZORPAY_KEY_ID=rzp_test_stub
RAZORPAY_WEBHOOK_SECRET=rzp_webhook_secret_stub

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW=900
AUTH_OTP_REQUEST_LIMIT=5
AUTH_OTP_VERIFY_LIMIT=10
RSVP_OTP_REQUEST_LIMIT=10
RSVP_OTP_VERIFY_LIMIT=20
PUBLIC_RSVP_SUBMIT_LIMIT=30

# Upstash REST Redis (distributed limiter)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional generic Redis URL (future use)
REDIS_URL=

# ---------- Observability ----------
LOG_LEVEL=info
SENTRY_DSN=
BETTERSTACK_HEARTBEAT_URL=
LOGTAIL_SOURCE_TOKEN=
